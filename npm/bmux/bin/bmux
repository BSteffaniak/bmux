#!/usr/bin/env node
"use strict";

const { argv } = process;
const { spawnSync } = require("child_process");
const { binaryPath } = require("../src/index.js");

const result = spawnSync(binaryPath, argv.slice(2), {
  shell: false,
  stdio: "inherit",
});

if (result.error) {
  throw result.error;
}

process.exitCode = result.status;
